<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="300.0" spacing="10.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="presentation.views.SensorController">
   <HBox prefHeight="100.0" prefWidth="200.0">
      <children>
         <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
         <ToggleButton mnemonicParsing="false" onAction="#handleHeartbeatToggle" selected="true" text="Heartbeat" />
      </children>
      <padding>
         <Insets right="10.0" top="10.0" />
      </padding>
   </HBox>
    <Label fx:id="spotIdLbl" text="1">
        <VBox.margin>
          <Insets bottom="20.0" />
        </VBox.margin>
        <font>
          <Font name="System Bold" size="24.0" />
        </font>
    </Label>
    <Button fx:id="sensorBtn" alignment="CENTER" contentDisplay="CENTER" maxHeight="80.0" minHeight="40.0" minWidth="120.0" mnemonicParsing="false" onAction="#handleSensorFired" text="Park">
        <font>
          <Font size="18.0" />
        </font>
    </Button>
    <Region prefHeight="26.0" prefWidth="600.0" VBox.vgrow="ALWAYS" />
    <TextArea fx:id="textField" maxHeight="225.0" minHeight="225.0" prefHeight="225.0" prefWidth="200.0" />
</VBox>
