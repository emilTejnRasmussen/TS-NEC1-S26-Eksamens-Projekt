<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="300.0" spacing="25.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="presentation.views.SensorController">
    <padding>
        <Insets top="25.0" />
    </padding>
    <Label fx:id="spotIdLbl" text="1">
        <VBox.margin>
          <Insets bottom="20.0" />
        </VBox.margin>
        <font>
          <Font name="System Bold" size="24.0" />
        </font>
    </Label>
    <Button fx:id="sensorBtn" alignment="CENTER" contentDisplay="CENTER" maxHeight="80.0" minHeight="40.0" minWidth="80.0" mnemonicParsing="false" onAction="#handleSensorFired" text="Park Car">
        <font>
          <Font size="18.0" />
        </font>
    </Button>
    <Region prefHeight="26.0" prefWidth="600.0" VBox.vgrow="ALWAYS" />
    <TextArea fx:id="textField" prefHeight="200.0" prefWidth="200.0" />
</VBox>
