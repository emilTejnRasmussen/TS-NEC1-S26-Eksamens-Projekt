      </children>
      <VBox.margin>
         <Insets right="10.0" top="10.0" />
      </VBox.margin>
   </HBox>
    <VBox fx:id="lightPane" alignment="CENTER" maxHeight="80.0" maxWidth="80.0" minHeight="80.0" minWidth="80.0" prefHeight="80.0" prefWidth="80.0" style="-fx-background-radius: 50; -fx-border-radius: 50; -fx-border-color: black; -fx-border-width: 4;">
        <Label fx:id="spotIdLbl" alignment="CENTER" contentDisplay="CENTER" text="1">
           <font>
               <Font name="System Bold" size="24.0" />
           </font>
        </Label>
    </VBox>
   <Region prefHeight="19.0" prefWidth="300.0" />
    <TextArea fx:id="textArea" maxHeight="225.0" minHeight="225.0" prefHeight="225.0" prefWidth="300.0" />
